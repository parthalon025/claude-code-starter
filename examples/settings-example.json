{
  "// INSTRUCTIONS": "Copy this file to ~/.claude/settings.json and customize it.",
  "// MODELS": "Options: opus[1m] (smartest), sonnet (fast+smart), haiku (fastest)",
  "permissions": {
    "allow": [
      "mcp__github__*",
      "mcp__filesystem__*",
      "WebSearch",
      "Bash(git *)",
      "Bash(npm test)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(python *)",
      "Bash(pip install *)",
      "Read(*)",
      "Glob(*)",
      "Grep(*)"
    ],
    "defaultMode": "default"
  },
  "model": "sonnet",
  "// PLUGINS": "These two work out of the box. Add others as needed (see claude-code-guide.md Section 8).",
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
